  "dynamics": [
    {"month": "2025-10", "top10": 8, "top50": 65, "traffic_month": 800},
    {"month": "2025-11", "top10": 10, "top50": 72, "traffic_month": 950},
    {"month": "2025-12", "top10": 12, "top50": 89, "traffic_month": 1200}
  ],

