#!/usr/bin/env bash
# pre-commit — белый список путей для worktree-режима.
#
# Правила:
#   - В main worktree (где .git — это директория, а не файл-указатель)
#     разрешено всё. Хук пропускает проверки.
#   - В дополнительной worktree разрешено менять файлы ТОЛЬКО:
#       * внутри папки текущей задачи (путь из .claude/tmp/current-task.txt)
#       * внутри .claude/tmp/  (служебные файлы сессии)
#       * внутри .claude/handoff-requests/  (запросы от /request-shared-edit)
#   - Любые другие изменения → exit 1 + список запрещённых файлов.
#
# Escape hatch: git commit --no-verify  (использовать только для системных коммитов).

set -u

GIT_DIR=$(git rev-parse --git-dir 2>/dev/null || true)
GIT_COMMON_DIR=$(git rev-parse --git-common-dir 2>/dev/null || true)

# Нормализация путей (на Windows git может вернуть . или абсолют)
case "${GIT_DIR}" in
  .) GIT_DIR=$(pwd)/.git ;;
esac
case "${GIT_COMMON_DIR}" in
  .) GIT_COMMON_DIR=$(pwd)/.git ;;
esac

if [ -z "${GIT_DIR}" ] || [ -z "${GIT_COMMON_DIR}" ]; then
  # Не git-репозиторий или странное состояние — не блокируем
  exit 0
fi

# --- Бэкстоп шаблона (доп. к ADR-003, 2026-05-31) ---
# Если это рабочий каталог ШАБЛОНА (есть untracked-маркер .claude/.is-template-root),
# запретить КОММИТ клиентских артефактов - иначе они засорят все будущие /new-project клоны.
# Второй рубеж к guard-template-root.sh: даже если клиентская команда как-то выполнилась,
# её результат не попадёт в шаблон. Удаления разрешены (--diff-filter=ACMR без D), чтобы
# можно было вычищать уже просочившееся. У клиентов маркера нет -> бэкстоп не активен (fail-safe).
PR_TMPL=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
if [ -f "${PR_TMPL}/.claude/.is-template-root" ]; then
  staged_am=$(git -c core.quotepath=false diff --cached --name-only --diff-filter=ACMR)
  tmpl_violations=""
  while IFS= read -r f; do
    [ -z "${f}" ] && continue
    case "${f}" in
      "ЗАКАЗЧИК.md"|"template.html"|"topics.xlsx"|"topics.json"|"QA-ЖУРНАЛ.md"|articles/*|analyses/*|structures/*|strategies/*|topics/*|metatags/*|audits/*|texts/*|faq/*|questions/*)
        tmpl_violations="${tmpl_violations}
  - ${f}" ;;
    esac
  done <<EOF
${staged_am}
EOF
  if [ -n "${tmpl_violations}" ]; then
    cat >&2 <<EOF
pre-commit: это рабочий каталог ШАБЛОНА (есть .claude/.is-template-root).
В шаблон нельзя коммитить клиентские артефакты - они засорят все будущие /new-project клоны.

Запрещённые добавления/изменения:${tmpl_violations}

Что делать:
  - Клиентские данные принадлежат проекту ~/seo-projects/<slug>/, не шаблону.
  - Случайная утечка: git restore --staged <файл> && git checkout -- <файл>
  - Удаление просочившегося разрешено (git rm <файл> хук пропускает).
EOF
    exit 1
  fi
fi
# --- конец бэкстопа шаблона ---

# В main worktree git-dir и git-common-dir указывают на ОДНО место.
# В дополнительной worktree они разные (git-dir = .git/worktrees/<name>, common-dir = основной .git).
if [ "${GIT_DIR}" = "${GIT_COMMON_DIR}" ]; then
  exit 0
fi

PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
TASK_FILE="${PROJECT_ROOT}/.claude/tmp/current-task.txt"

if [ ! -f "${TASK_FILE}" ]; then
  cat >&2 <<EOF
pre-commit: worktree-сессия не объявила текущую задачу.

Файл ${TASK_FILE} не найден. Любой скил, работающий с задачей
(seo-statya, fix-article, и др.), должен записать туда путь к папке задачи
до первого коммита.

Если ты делаешь системный коммит без привязки к задаче:
  git commit --no-verify
EOF
  exit 1
fi

# Серийный режим (Block D): current-task.txt может содержать НЕСКОЛЬКО задач -
# по одной на строку. Так серия статей, написанных в одной worktree-сессии
# (/seo-statya 11-20), коммитится и хендофится одним разом без --no-verify.
# Каждая непустая строка = папка задачи, которой владеет эта сессия. Одна строка -
# обычный одиночный режим (полная обратная совместимость).
allowed_prefixes=(
  ".claude/tmp/"
  ".claude/handoff-requests/"
)
task_rels=""   # для сообщения об ошибке
task_count=0

while IFS= read -r raw_line || [ -n "${raw_line}" ]; do
  task_dir=$(printf '%s' "${raw_line}" | tr -d '\r\n')
  [ -z "${task_dir}" ] && continue

  # Преобразуем task_dir в относительный путь относительно PROJECT_ROOT
  case "${task_dir}" in
    /*|[a-zA-Z]:*)
      case "${task_dir}" in
        "${PROJECT_ROOT}"/*) task_rel="${task_dir#${PROJECT_ROOT}/}" ;;
        *) task_rel="${task_dir}" ;;
      esac
      ;;
    *) task_rel="${task_dir}" ;;
  esac

  # Убираем хвостовой слэш
  task_rel="${task_rel%/}"
  [ -z "${task_rel}" ] && continue

  allowed_prefixes+=("${task_rel}/")
  task_rels="${task_rels}
  - ${task_rel}/"
  task_count=$((task_count + 1))
done < "${TASK_FILE}"

if [ "${task_count}" -eq 0 ]; then
  echo "pre-commit: current-task.txt содержит только пустые строки — отказ в коммите" >&2
  exit 1
fi

# Дополнительно разрешённые файлы по точному имени.
# (ADR-013) Реестры _index.json больше НЕ коммитятся - это производные кеши,
# gitignored, пересобираются из per-folder meta.json (rebuild-index.mjs). Белого
# списка для них не нужно: их не видит git => ноль merge-конфликтов при параллели.
allowed_files=(
)

# -c core.quotepath=false обязателен: иначе non-ASCII имена (например ЗАКАЗЧИК.md)
# git эскейпит в octal и оборачивает в двойные кавычки (".../\320\227...") —
# ведущая кавычка ломает case-матч по разрешённым префиксам, и разрешённый файл
# ошибочно считается нарушением. С quotepath=false путь приходит чистым UTF-8.
changed=$(git -c core.quotepath=false diff --cached --name-only)

violations=""
while IFS= read -r f; do
  [ -z "${f}" ] && continue
  ok=0
  for p in "${allowed_prefixes[@]}"; do
    case "${f}" in
      "${p}"*) ok=1; break ;;
    esac
  done
  if [ "${ok}" != "1" ] && [ "${#allowed_files[@]}" -gt 0 ]; then
    for af in "${allowed_files[@]}"; do
      if [ "${f}" = "${af}" ]; then
        ok=1
        break
      fi
    done
  fi
  if [ "${ok}" != "1" ]; then
    violations="${violations}
  - ${f}"
  fi
done <<EOF
${changed}
EOF

if [ -n "${violations}" ]; then
  cat >&2 <<EOF
pre-commit: В worktree запрещено менять файлы вне текущей задачи.

Задачи этой сессии (current-task.txt):${task_rels}
Разрешённые зоны:
  - <папка каждой задачи выше>/  (своя задача / задачи серии)
  - .claude/tmp/       (служебные файлы сессии)
  - .claude/handoff-requests/  (запросы для main)

Запрещённые изменения в этом коммите:${violations}

Что делать с общими файлами (ЗАКАЗЧИК.md, template.html, topics.xlsx и т.п.):
  - В этой сессии: /request-shared-edit "<описание правки>"
    Запрос уедет в main при /handoff, обработается через /handoff-process.
  - Или открой main-сессию (без галочки worktree) и правь напрямую.

Системный обход (не рекомендуется):
  git commit --no-verify
EOF
  exit 1
fi

exit 0
